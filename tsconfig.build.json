/* Declaration-only build for the published library (excludes the example app).
 * esbuild emits the JS; this emits the matching .d.ts tree into dist/. */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": true,
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/example/**", "node_modules", "dist"]
}
