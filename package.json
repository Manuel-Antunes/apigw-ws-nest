{
  "name": "apigw-ws-nest",
  "version": "1.0.0",
  "description": "NestJS custom WebSocketAdapter over AWS API Gateway WebSocket + DynamoDB Streams, with a Lambda handler and a local emulator",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node src/example/src/local-server.ts",
    "start:http": "ts-node src/example/src/bootstrap.ts",
    "start:http:aws": "RT_PROVIDER=aws ts-node src/example/src/bootstrap.ts",
    "deploy": "sst deploy --stage dev",
    "remove": "sst remove --stage dev"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/websockets": "^11.0.0",
    "dotenv": "^17.4.2",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "ws": "^8.17.0"
  },
  "optionalDependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.600.0",
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "@aws-sdk/util-dynamodb": "^3.600.0"
  },
  "devDependencies": {
    "@nestjs/platform-ws": "^11.1.27",
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "sst": "^3.19.3",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
